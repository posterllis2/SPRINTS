section .data
    limite_carga    dd 100          ; Valor máximo da bateria
    msg_carregando  db 'Carregando... ', 0xA
    len_carregando  equ $ - msg_carregando
    msg_concluido   db 'Carga completa. Entrando em modo Economico.', 0xA
    len_concluido   equ $ - msg_concluido

section .text
    global _start

_start:
    ; 1. Inicialização de Registradores
    mov ebx, [limite_carga]         ; EBX guarda o limite (100)
    mov ecx, 0                      ; ECX será o nosso sensor (0%)

loop_controle:
    ; 2. Simulação de leitura de hardware
    add ecx, 10                     ; Aumenta 10% a cada ciclo

    ; 3. Comparação
    cmp ecx, ebx                    ; Compara sensor (ECX) com limite (EBX)
    jge carga_finalizada            ; Se for maior ou igual a 100, pula para o fim

    ; 4. Exibir "Carregando..." (Syscall de escrita no Linux)
    mov eax, 4                      ; System call number para sys_write
    mov ebx, 1                      ; File descriptor 1 (stdout)
    mov ecx, msg_carregando         ; Ponteiro para a mensagem
    mov edx, len_carregando         ; Tamanho da mensagem
    int 0x80                        ; Chama o kernel
    
    ; Recupera o valor do sensor que estava no ECX (o syscall muda o ECX)
    ; Para simplificar no primeiro semestre, vamos simular o sensor voltando
    mov ecx, [valor_atual]          ; (Apenas ilustrativo)
    
    ; 5. Otimização (Simulada pelo salto de volta)
    jmp loop_controle

carga_finalizada:
    ; Ação de Desligamento (Sustentabilidade)
    mov eax, 4                      ; sys_write
    mov ebx, 1                      ; stdout
    mov ecx, msg_concluido          ; mensagem final
    mov edx, len_concluido          ; tamanho
    int 0x80

encerra_processamento:
    ; Finaliza o programa
    mov eax, 1                      ; System call para sys_exit
    xor ebx, ebx                    ; Retorno 0 (sucesso)
    int 0x80

section .bss
    valor_atual resd 1              ; Reserva espaço para o sensor
